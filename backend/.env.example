# ──────────────────────────────────────────────────────────────
# ArriBot Backend — Required Environment Variables
# Copy this file to .env and fill in all values before running.
# NONE of these have fallback defaults in application.properties.
# ──────────────────────────────────────────────────────────────

# Server
PORT=8080

# MongoDB Atlas — required
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/arribot?retryWrites=true&w=majority

# Groq AI — required (all AI features use Groq)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Brevo (Sendinblue) Email — required
BREVO_API_KEY=xkeysib-your-brevo-api-key-here
BREVO_FROM_EMAIL=your-verified-sender@example.com

# JWT — required (use a long, random string)
JWT_SECRET=your-very-long-random-jwt-secret-at-least-32-chars

# CORS — optional (defaults to localhost dev ports)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File uploads — optional
FILE_UPLOAD_DIR=./uploads/resumes
